{
  "_meta": {
    "description": "分层两 pass：Pass1 场景+光影 {{POSITIVE_SCENE_BG}} → Pass2 img2img 叠主体 {{POSITIVE_SUBJECT_FG}}，denoise={{DENOISE_SUBJECT}}",
    "format": "comfyui_api",
    "preset_id": "sdxl_layered",
    "notes": "标准节点两阶段；Pass1=prefix+scene+light，Pass2=prefix+subject。参考 SDXL base→refiner 分阶段思路。"
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{CHECKPOINT}}"
    }
  },
  "2": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "batch_size": 1
    }
  },
  "10": {
    "class_type": "CLIPTextEncodeSDXL",
    "inputs": {
      "clip": ["1", 1],
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "crop_w": 0,
      "crop_h": 0,
      "target_width": "{{WIDTH}}",
      "target_height": "{{HEIGHT}}",
      "text_g": "{{POSITIVE_SCENE_BG}}",
      "text_l": "{{POSITIVE_SCENE_BG}}"
    }
  },
  "11": {
    "class_type": "CLIPTextEncodeSDXL",
    "inputs": {
      "clip": ["1", 1],
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "crop_w": 0,
      "crop_h": 0,
      "target_width": "{{WIDTH}}",
      "target_height": "{{HEIGHT}}",
      "text_g": "{{NEGATIVE}}",
      "text_l": "{{NEGATIVE}}"
    }
  },
  "12": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG}}",
      "sampler_name": "{{SAMPLER}}",
      "scheduler": "{{SCHEDULER}}",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["10", 0],
      "negative": ["11", 0],
      "latent_image": ["2", 0]
    }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["12", 0],
      "vae": ["1", 2]
    }
  },
  "14": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["13", 0],
      "vae": ["1", 2]
    }
  },
  "20": {
    "class_type": "CLIPTextEncodeSDXL",
    "inputs": {
      "clip": ["1", 1],
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "crop_w": 0,
      "crop_h": 0,
      "target_width": "{{WIDTH}}",
      "target_height": "{{HEIGHT}}",
      "text_g": "{{POSITIVE_SUBJECT_FG}}",
      "text_l": "{{POSITIVE_SUBJECT_FG}}"
    }
  },
  "21": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG}}",
      "sampler_name": "{{SAMPLER}}",
      "scheduler": "{{SCHEDULER}}",
      "denoise": "{{DENOISE_SUBJECT}}",
      "model": ["1", 0],
      "positive": ["20", 0],
      "negative": ["11", 0],
      "latent_image": ["14", 0]
    }
  },
  "22": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["21", 0],
      "vae": ["1", 2]
    }
  },
  "23": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["22", 0],
      "filename_prefix": "{{FILENAME_PREFIX}}"
    }
  }
}
