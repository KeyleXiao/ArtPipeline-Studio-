{
  "_meta": {
    "description": "SDXL 文生图 · 四段 prompt 映射 G/L。G={{POSITIVE_G}} L={{POSITIVE_L}}；亦支持 {{POSITIVE_PREFIX}} 等分段占位符。",
    "format": "comfyui_api",
    "preset_id": "sdxl_split_gl",
    "notes": "G=画质+主体+场景，L=主体+场景+光影（由 ArtPipeline 根据四段自动合并）"
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{CHECKPOINT}}"
    }
  },
  "2": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "batch_size": 1
    }
  },
  "3": {
    "class_type": "CLIPTextEncodeSDXL",
    "inputs": {
      "clip": ["1", 1],
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "crop_w": 0,
      "crop_h": 0,
      "target_width": "{{WIDTH}}",
      "target_height": "{{HEIGHT}}",
      "text_g": "{{POSITIVE_G}}",
      "text_l": "{{POSITIVE_L}}"
    }
  },
  "4": {
    "class_type": "CLIPTextEncodeSDXL",
    "inputs": {
      "clip": ["1", 1],
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "crop_w": 0,
      "crop_h": 0,
      "target_width": "{{WIDTH}}",
      "target_height": "{{HEIGHT}}",
      "text_g": "{{NEGATIVE}}",
      "text_l": "{{NEGATIVE}}"
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG}}",
      "sampler_name": "{{SAMPLER}}",
      "scheduler": "{{SCHEDULER}}",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["2", 0]
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "{{FILENAME_PREFIX}}"
    }
  }
}
